rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. PUBLIC DONATIONS - ABSOLUTE PRIORITY
    // This MUST stay at the very top level and match both GET and LIST
    match /donations/{id} {
      allow read, write: if true;
    }

    // 2. ADMIN SECURITY
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@ward.hamro' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Admin match (lower priority than specific collection matches)
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // 3. OTHER PUBLIC COLLECTIONS
    match /sponsors/{id} { allow read: if true; }
    match /notifications/{id} { allow read: if true; }
    match /documents/{id} { allow read: if true; }
    match /videos/{id} {
      allow read: if true;
      allow create: if request.auth != null;
    }
    match /issues/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /users/{userId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && request.auth.uid == userId;
    }
    match /comments/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
